{
  "name": "Workforce Intelligence Executive",
  "background": "#F6F7F2",
  "foreground": "#1F2933",
  "tableAccent": "#1F5A78",
  "good": "#2A9D8F",
  "neutral": "#D9A441",
  "bad": "#C94C4C",
  "maximum": "#1F5A78",
  "center": "#5DA9E9",
  "minimum": "#DCEAF5",
  "dataColors": [
    "#1F5A78",
    "#5DA9E9",
    "#D9A441",
    "#C94C4C",
    "#2A9D8F",
    "#7A8A99",
    "#6C8EAD",
    "#88C0D0"
  ],
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F6F7F2"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "alignment": "left"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#5B5B5B"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "title": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            }
          }
        ],
        "items": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "fontColor": {
              "solid": {
                "color": "#5B5B5B"
              }
            }
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": false,
            "gridHorizontal": true,
            "outlineColor": {
              "solid": {
                "color": "#E7EAEE"
              }
            },
            "gridHorizontalColor": {
              "solid": {
                "color": "#E7EAEE"
              }
            }
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 10,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "backColor": {
              "solid": {
                "color": "#F8FAFB"
              }
            }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "fontColor": {
              "solid": {
                "color": "#3E4C59"
              }
            }
          }
        ]
      }
    },
    "barChart": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#3E4C59"
              }
            },
            "fontSize": 10
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#5B5B5B"
              }
            },
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#5B5B5B"
              }
            },
            "fontSize": 10
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#3E4C59"
              }
            },
            "fontSize": 10
          }
        ],
        "categoryAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#5B5B5B"
              }
            },
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "labelColor": {
              "solid": {
                "color": "#5B5B5B"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}
